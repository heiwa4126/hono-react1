{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"strict": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"types": ["node"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"outDir": "./dist",

		// import aliases
		"paths": {
			"@shared/*": ["../../packages/shared/src/*"],
		},
	},
	"exclude": ["node_modules"],
}
